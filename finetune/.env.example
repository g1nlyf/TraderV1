# Fine-tuning environment variables
# Copy to .env and fill in values

# Phase 1: teacher data collection via OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...
# Model: openrouter/owl-alpha (set in training_config.yaml or CLI flag)

# Phase 3: fine-tuning via Together.ai
TOGETHER_API_KEY=...
# After training completes, set the returned model ID:
# TOGETHER_FINETUNED_MODEL=ft-traderv1-qwen25-7b-abc123

# Optional: OpenAI as alternative fine-tuning provider
# OPENAI_API_KEY=sk-...
# OPENAI_FINETUNED_MODEL=ft:gpt-4o-mini-2024-07-18:your-org:traderv1:abc123

# Teacher model override (default: openrouter/owl-alpha)
# TEACHER_MODEL=openrouter/owl-alpha
